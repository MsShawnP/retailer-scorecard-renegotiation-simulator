{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "retailer-scorecard-renegotiation-simulator",
  "compatibility_date": "2026-05-09",
  "observability": {
    "enabled": true
  },
  "assets": {
    "not_found_handling": "single-page-application"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "routes": [
    { "pattern": "retailer-scorecard.lailarallc.com", "custom_domain": true }
  ]
}
